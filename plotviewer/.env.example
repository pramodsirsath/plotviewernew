# Leave VITE_API_URL empty in local development.
# The Vite dev server proxies /api and /uploads to the backend target below,
# so the app works from both localhost and your LAN IP when you run `npm run dev`.
# VITE_API_URL=

# Required for Google Maps layout placement and read-only overlay views.
VITE_GOOGLE_MAPS_API_KEY=

# Optional: change this only if your backend is not running on localhost:5000.
VITE_DEV_PROXY_TARGET=http://127.0.0.1:5000
